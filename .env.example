# Emby connection
EMBY_URL=http://localhost:8096
EMBY_API_KEY=replace-with-your-emby-api-key

# Empulse web server
EMPULSE_HOST=127.0.0.1
EMPULSE_PORT=8189

# Polling and storage
POLL_INTERVAL=10
DB_PATH=./empulse.db

# Optional fallback admin login when Emby auth is unavailable
AUTH_PASSWORD=

# Optional explicit session signing key
# Leave empty to let Empulse generate and persist one automatically.
SECRET_KEY=

# Update checker
DISABLE_UPDATE_CHECK=false
